{
  "name": "signalgraph-site",
  "type": "module",
  "version": "0.3.0",
  "private": true,
  "description": "Signalgraph — grounded signal on AI, quantum, and the systems underneath. Public blog; content arrives only via curator-merged PRs from the private engine.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy",
    "worker:dev": "npm run build && wrangler dev"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@dagrejs/dagre": "^1.1.4",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/space-grotesk": "^5.2.5",
    "@huggingface/transformers": "^4.2.0",
    "@pagefind/default-ui": "^1.3.0",
    "astro": "^5.12.0",
    "pagefind": "^1.3.0"
  },
  "devDependencies": {
    "wrangler": "^4.112.0"
  }
}
