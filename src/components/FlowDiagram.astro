---
/**
 * THE Flowkit stencil renderer — every Signalgraph diagram is drawn by this
 * component from DSL JSON. Stencil vocabulary (closed set):
 *   nodes: stage (rect r6) · store (3px top bar) · model (corner notch) ·
 *          external (dashed) · human (pill)
 *   edges: flow (marching dash over a faint solid) · trigger (dotted, static) ·
 *          feedback (dashed return)
 * Signal teal is reserved for the ONE primary edge (+ its traveling dot).
 * Animation runs only in-viewport; prefers-reduced-motion zeroes durations
 * (tokens.css) and hides the dot.
 */
import { layoutDiagram } from "../lib/flowkit.mjs";

interface Props {
  dsl: any;
}
const d = layoutDiagram(Astro.props.dsl);
const HUES: Record<string, string> = {
  agentic: "var(--pillar-agentic)",
  hardware: "var(--pillar-hardware)",
  quantum: "var(--pillar-quantum)",
  data: "var(--pillar-data)",
  practice: "var(--pillar-practice)",
};
const primary = d.edges.find((e: any) => e.primary);
---

<figure class="flowkit" data-flowkit data-title={d.title}>
  <div class="title-row">
    <figcaption>{d.title}</figcaption>
    <button type="button" class="zoom-toggle" aria-label={`Open ${d.title} in fullscreen`}>Zoom</button>
  </div>
  <div class="scroller">
    <svg
      viewBox={`${d.vx} ${d.vy} ${d.width} ${d.height}`}
      width={d.width}
      height={d.height}
      role="img"
      aria-label={`Diagram: ${d.title}`}
    >
      <defs>
        <marker id="arr-m" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0,0 L10,5 L0,10 z" fill="var(--muted)"></path>
        </marker>
        <marker id="arr-t" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
          <path d="M0,0 L10,5 L0,10 z" fill="var(--accent)"></path>
        </marker>
      </defs>

      {d.groups.map((grp: any) => (
        <g class="grp">
          <rect
            x={grp.x} y={grp.y} width={grp.w} height={grp.h} rx="12"
            fill={HUES[grp.hue] ?? "var(--muted)"} fill-opacity="0.12"
            stroke="var(--hairline)" stroke-dasharray="5 4"
          ></rect>
          <text x={grp.x + 12} y={grp.y + 18} class="grp-label">{grp.label}</text>
        </g>
      ))}

      {d.edges.map((e: any) => (
        <g class={`edge k-${e.kind}${e.primary ? " primary" : ""}`}>
          {e.kind === "flow" && <path class="base" d={e.path} pathLength="1"></path>}
          <path
            class="line"
            d={e.path}
            pathLength="1"
            marker-end={e.primary ? "url(#arr-t)" : "url(#arr-m)"}
          ></path>
          {e.label && (
            <g>
              <rect
                x={e.lx - (e.label.length * 7 + 12) / 2} y={e.ly - 10}
                width={e.label.length * 7 + 12} height="20" rx="5"
                fill="var(--bg)"
              ></rect>
              <text x={e.lx} y={e.ly + 4} text-anchor="middle" class="edge-label">{e.label}</text>
            </g>
          )}
        </g>
      ))}

      {primary && (
        <circle class="flow-dot" r="4" style={`offset-path: path('${primary.path}')`}></circle>
      )}

      {d.nodes.map((n: any) => (
        <g class={`node t-${n.type}`}>
          {n.type === "model" ? (
            <path
              d={`M${n.x},${n.y} h${n.w - 12} l12,12 v${n.h - 12} h${-n.w} v${-n.h} z`}
              class="shape"
            ></path>
          ) : (
            <rect
              x={n.x} y={n.y} width={n.w} height={n.h}
              rx={n.type === "human" ? n.h / 2 : 8}
              class="shape"
            ></rect>
          )}
          {n.type === "store" && (
            <rect x={n.x + 8} y={n.y} width={n.w - 16} height="3.5" fill="var(--diagram-stroke)"></rect>
          )}
          <text x={n.x + n.w / 2} y={n.y + (n.sub ? n.h / 2 - 4 : n.h / 2 + 5)} text-anchor="middle" class="label">
            {n.label}
          </text>
          {n.sub && (
            <text x={n.x + n.w / 2} y={n.y + n.h / 2 + 16} text-anchor="middle" class="sub">{n.sub}</text>
          )}
        </g>
      ))}
    </svg>
  </div>
</figure>

<div class="zoom-overlay" hidden role="dialog" aria-modal="true" aria-label={`Expanded view of ${d.title}`}>
  <div class="zoom-panel">
    <div class="zoom-header">
      <p>{d.title}</p>
      <button type="button" class="zoom-close" aria-label="Close zoom view">Close</button>
    </div>
    <div class="zoom-body"></div>
  </div>
</div>

<script>
  /* Animations run only while the diagram is on screen. */
  function observe() {
    const io = new IntersectionObserver(
      (entries) => entries.forEach((en) => en.target.classList.toggle("in-view", en.isIntersecting)),
      { threshold: 0.15 },
    );
    document.querySelectorAll("[data-flowkit]").forEach((el) => io.observe(el));
  }

  // Astro dedupes identical inline <script> blocks across repeated component
  // instances, so this runs ONCE per page even when a post has several
  // diagrams (Deep Dive/Teardown formats plan for 2-4). A single global
  // querySelector would wire the zoom button only to the FIRST diagram —
  // every other diagram's zoom would silently do nothing. Each <figure> is
  // scoped to its own adjacent .zoom-overlay sibling instead.
  function setupZoom() {
    document.querySelectorAll("[data-flowkit]").forEach((figure) => {
      if (!(figure instanceof HTMLElement) || figure.dataset.zoomBound === "1") return;
      const overlay = figure.nextElementSibling;
      if (!(overlay instanceof HTMLElement) || !overlay.classList.contains("zoom-overlay")) return;
      const body = overlay.querySelector(".zoom-body");
      const closeButton = overlay.querySelector(".zoom-close");
      if (!body) return;
      figure.dataset.zoomBound = "1";

      const open = () => {
        // The .zoom-toggle button is the only <button> inside `figure` and IS
        // the intended, accessible (labeled, keyboard-reachable) trigger —
        // clicking anywhere else on the figure is a convenience shortcut for
        // the same action. Neither should be excluded.
        const source = figure.querySelector("svg");
        if (!source) return;
        body.innerHTML = "";
        const clone = source.cloneNode(true);
        clone.classList.add("zoom-svg");
        body.appendChild(clone);
        overlay.hidden = false;
        document.body.classList.add("zoom-open");
      };
      const close = () => {
        overlay.hidden = true;
        body.innerHTML = "";
        document.body.classList.remove("zoom-open");
      };

      figure.addEventListener("click", open);
      closeButton?.addEventListener("click", close);
      overlay.addEventListener("click", (event) => {
        if (event.target === overlay) close();
      });
    });
  }

  // One document-level Escape listener closes whichever overlay is open —
  // bound once (guarded), not once per figure.
  function setupEscape() {
    if (document.documentElement.dataset.flowkitEscapeBound === "1") return;
    document.documentElement.dataset.flowkitEscapeBound = "1";
    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      document.querySelectorAll(".zoom-overlay").forEach((overlay) => {
        if (overlay instanceof HTMLElement && !overlay.hidden) {
          overlay.hidden = true;
          const body = overlay.querySelector(".zoom-body");
          if (body) body.innerHTML = "";
          document.body.classList.remove("zoom-open");
        }
      });
    });
  }

  observe();
  setupZoom();
  setupEscape();
  document.addEventListener("astro:after-swap", () => {
    observe();
    setupZoom();
  });
</script>

<style>
  .flowkit {
    margin: calc(var(--space-unit) * 4) auto;
    width: min(100%, 78rem);
    max-width: none;
    cursor: zoom-in;
  }
  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .zoom-toggle,
  .zoom-close {
    border: 1px solid var(--hairline);
    border-radius: 999px;
    background: var(--bg);
    color: var(--ink);
    padding: 0.45rem 0.8rem;
    font: inherit;
    cursor: pointer;
  }
  .zoom-toggle:hover,
  .zoom-close:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .scroller {
    overflow-x: auto; /* phones pan; text never squashes */
    border: 1px solid var(--hairline);
    border-radius: 16px;
    background: var(--bg-raised);
    padding: calc(var(--space-unit) * 1.5);
  }
  svg {
    display: block;
    margin-inline: auto;
    max-width: 100%;
    height: auto;
    min-width: 640px;
    font-family: var(--font-body);
  }
  figcaption {
    text-align: left;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .shape {
    fill: var(--diagram-surface);
    stroke: var(--diagram-stroke);
    stroke-width: 1.4;
  }
  .t-external .shape {
    stroke-dasharray: 5 4;
    stroke: var(--diagram-stroke);
  }
  .t-human .shape {
    stroke: var(--diagram-label);
  }
  .label {
    font-size: 14px;
    font-weight: 700;
    fill: var(--diagram-label);
  }
  .sub {
    font-size: 12px;
    fill: var(--diagram-muted);
  }
  .grp-label {
    font-size: 12px;
    font-family: var(--font-mono);
    fill: var(--diagram-muted);
    letter-spacing: 0.04em;
  }
  .edge-label {
    font-size: 12px;
    fill: var(--diagram-muted);
  }

  .edge .line {
    fill: none;
    stroke: var(--diagram-stroke);
    stroke-width: 1.7;
  }
  .edge .base {
    fill: none;
    stroke: var(--diagram-stroke);
    stroke-opacity: 0.28;
    stroke-width: 1.7;
  }
  .k-flow .line {
    stroke-dasharray: 0.06 0.05; /* pathLength-normalized marching dash */
    animation: march var(--flow-dash-duration) linear infinite;
  }
  .k-trigger .line {
    stroke-dasharray: 0.012 0.03;
    stroke-linecap: round;
  }
  .k-feedback .line {
    stroke-dasharray: 0.045 0.035;
    stroke-opacity: 0.8;
  }
  .edge.primary .line,
  .edge.primary .base {
    stroke: var(--accent);
  }
  .flow-dot {
    fill: var(--accent);
    offset-rotate: 0deg;
    animation: travel var(--flow-dot-duration) linear infinite;
  }
  .zoom-overlay {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: grid;
    place-items: center;
    padding: 1rem;
    background: rgba(4, 6, 11, 0.84);
  }
  .zoom-overlay[hidden] {
    display: none;
  }
  .zoom-panel {
    width: min(96vw, 1100px);
    max-height: 94vh;
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: 18px;
    background: var(--bg-raised);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.35);
  }
  .zoom-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--hairline);
  }
  .zoom-header p {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
  }
  .zoom-body {
    padding: 1rem;
    overflow: auto;
  }
  .zoom-svg {
    width: 100%;
    height: auto;
    min-width: 680px;
  }
  body.zoom-open {
    overflow: hidden;
  }
  @keyframes march {
    to {
      stroke-dashoffset: -0.11;
    }
  }
  @keyframes travel {
    from {
      offset-distance: 0%;
    }
    to {
      offset-distance: 100%;
    }
  }
  /* paused off-screen; reduced-motion zeroes durations via tokens + hides the dot */
  .flowkit:not(.in-view) :is(.line, .flow-dot) {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .flow-dot {
      display: none;
    }
  }
</style>
