---
/**
 * Inline header search — the WS4 blended engine (Pagefind text + in-browser
 * semantic vectors, normalized 0-1 per source and summed under a
 * deterministic query-bias heuristic, no LLM) presented as a dropdown panel
 * from the site header instead of a separate /search/ page.
 *
 * Cost discipline: the Pagefind runtime loads on first OPEN of the panel,
 * the semantic model (transformers.js bge-small, q8) on first QUERY — a
 * reader who never touches search downloads neither.
 */
---

<div class="hs-root" data-header-search>
  <button type="button" class="hs-trigger" aria-expanded="false" aria-controls="hs-panel">search</button>
  <div class="hs-panel" id="hs-panel" role="search" aria-label="Search Signalgraph" hidden>
    <form class="hs-form">
      <label class="sr-only" for="hs-q">Search Signalgraph</label>
      <input id="hs-q" type="search" placeholder="Try a title, phrase, or question…" autocomplete="off" />
    </form>
    <p class="hs-status" aria-live="polite"></p>
    <ol class="hs-results"></ol>
  </div>
</div>

<script type="module" is:inline>
  // Unprocessed on purpose: /pagefind/pagefind.js exists only in the built
  // output, so the import must stay a literal runtime path. Memoized and
  // called lazily — the panel's first open triggers it, not page load.
  window.__loadPagefind ??= () => {
    window.__pagefindPromise ??= import("/pagefind/pagefind.js")
      .then((mod) => mod?.default ?? mod)
      .catch((error) => {
        console.warn("Pagefind runtime could not be loaded.", error);
        return null;
      });
    return window.__pagefindPromise;
  };
</script>

<script>
  type SearchResultEntry = {
    slug: string;
    title: string;
    href: string;
    excerpt: string;
    score: number;
    sources: Array<"text" | "semantic">;
  };

  let semanticExtractor: any = null;
  let semanticIndex: any = null;
  let activeRequest = 0;
  let searchTimer: number | undefined;

  function getQueryBias(query: string) {
    const trimmed = query.trim();
    const words = trimmed.split(/\s+/).filter(Boolean);
    const quoted = /".+?"/.test(trimmed);
    const operators = /(?:^|\s)(AND|OR|NOT|[+\-])/i.test(trimmed);
    const shortKeyword = words.length <= 2;
    const question = /\?|(?:^|\s)(what|why|when|where|which|who|how|can|should|does|do|is|are|will|tell|explain)\b/i.test(trimmed);
    const longPhrase = words.length >= 4;
    // quoted / operators / <=2 words read as a keyword lookup -> favor text.
    if (quoted || operators || shortKeyword) return { text: 1.25, semantic: 0.82 };
    // >=4 words or a question word reads as natural language -> favor semantic.
    if (longPhrase || question) return { text: 0.9, semantic: 1.12 };
    return { text: 1.0, semantic: 1.0 };
  }

  function normalizeExcerpt(text: string) {
    return text.replace(/\s+/g, " ").trim();
  }

  function slugFromUrl(url: string) {
    try {
      const parsed = new URL(url, window.location.origin);
      const pathname = parsed.pathname.replace(/^\/+/, "").replace(/\/$/, "");
      if (pathname.startsWith("posts/")) return pathname.replace(/^posts\//, "");
      return pathname;
    } catch {
      return "";
    }
  }

  function toHref(url: string, slug: string) {
    if (!slug) return "/posts/";
    if (url.startsWith("http")) {
      const parsed = new URL(url, window.location.origin);
      return parsed.pathname;
    }
    if (url.startsWith("/posts/")) return url;
    return `/posts/${slug}/`;
  }

  async function runTextSearch(query: string) {
    try {
      const api = await (window as any).__loadPagefind?.();
      if (!api?.search) {
        return { entries: [] as SearchResultEntry[], status: "Text search is not available in this environment yet." };
      }
      await api.options({ excerptLength: 18 });
      const results = await api.search(query);
      const entries = await Promise.all(
        (results.results || []).slice(0, 8).map(async (result: any) => {
          const fragment = await result.data();
          const slug = slugFromUrl(fragment?.url || fragment?.raw_url || "");
          const href = toHref(fragment?.url || fragment?.raw_url || "", slug);
          return {
            slug,
            title: fragment?.meta?.title || fragment?.title || "Untitled",
            href,
            excerpt: normalizeExcerpt(fragment?.excerpt || fragment?.content || ""),
            score: Number(result.score || 0),
            sources: ["text"] as Array<"text" | "semantic">,
          } satisfies SearchResultEntry;
        }),
      );
      return { entries: entries.filter((entry) => entry.slug), status: `${entries.length} text match${entries.length === 1 ? "" : "es"}` };
    } catch (error) {
      console.warn("Text search failed.", error);
      return { entries: [] as SearchResultEntry[], status: "Text search failed; showing semantic results only." };
    }
  }

  async function runSemanticSearch(query: string) {
    if (!query.trim()) return { entries: [] as SearchResultEntry[], status: "" };

    if (!semanticIndex) {
      const res = await fetch("/search/vectors.json").catch(() => null);
      semanticIndex = res?.ok ? await res.json() : { posts: [] };
    }

    if (!semanticIndex?.posts?.length) {
      return { entries: [] as SearchResultEntry[], status: "No semantic vectors are available yet." };
    }

    if (!semanticExtractor) {
      try {
        const { pipeline } = await import("@huggingface/transformers");
        semanticExtractor = await pipeline("feature-extraction", "Xenova/bge-small-en-v1.5", { dtype: "q8" });
      } catch (error) {
        console.warn("Semantic model did not load.", error);
        return { entries: [] as SearchResultEntry[], status: "Semantic model could not be loaded in this browser." };
      }
    }

    const out = await semanticExtractor(
      "Represent this sentence for searching relevant passages: " + query,
      { pooling: "mean", normalize: true },
    );
    const q: Float32Array = out.data;
    const scored = semanticIndex.posts
      .map((post: any) => {
        let dot = 0;
        let norm = 0;
        for (let i = 0; i < q.length; i++) {
          const v = post.v[i] * post.scale;
          dot += q[i] * v;
          norm += v * v;
        }
        return { post, score: dot / Math.sqrt(norm || 1) };
      })
      .sort((a: any, b: any) => b.score - a.score)
      .slice(0, 8);

    const entries = scored.map(({ post, score }: any) => ({
      slug: post.slug,
      title: post.title || "Untitled",
      href: `/posts/${post.slug}/`,
      excerpt: `Semantic match for “${query.trim()}”.`,
      score,
      sources: ["semantic"] as Array<"text" | "semantic">,
    }));
    return { entries, status: `${entries.length} semantic match${entries.length === 1 ? "" : "es"}` };
  }

  function mergeResults(text: SearchResultEntry[], semantic: SearchResultEntry[], query: string) {
    const bias = getQueryBias(query);
    // Per the brief's blend rule: normalize each SOURCE's scores to 0-1
    // (Pagefind relevance vs cosine similarity aren't comparable raw), then
    // SUM the biased normalized scores per slug — summing rewards a post
    // both signals agree on. Each entry is biased exactly once, at push time.
    const normalize = (entries: SearchResultEntry[]) => {
      const top = Math.max(...entries.map((entry) => entry.score), 0);
      return top > 0 ? entries.map((entry) => ({ ...entry, score: entry.score / top })) : entries;
    };
    const merged = new Map<string, SearchResultEntry>();
    const pushEntry = (entry: SearchResultEntry, biasFactor: number) => {
      const biasedScore = entry.score * biasFactor;
      const current = merged.get(entry.slug);
      if (!current) {
        merged.set(entry.slug, { ...entry, score: biasedScore });
      } else {
        merged.set(entry.slug, {
          ...current,
          score: current.score + biasedScore,
          sources: [...new Set([...current.sources, ...entry.sources])] as Array<"text" | "semantic">,
        });
      }
    };

    for (const entry of normalize(text)) pushEntry(entry, bias.text);
    for (const entry of normalize(semantic)) pushEntry(entry, bias.semantic);
    return Array.from(merged.values()).sort((a, b) => b.score - a.score);
  }

  function renderResults(root: HTMLElement, entries: SearchResultEntry[], statusText: string) {
    const list = root.querySelector(".hs-results") as HTMLOListElement | null;
    const status = root.querySelector(".hs-status") as HTMLParagraphElement | null;
    if (!list || !status) return;
    list.innerHTML = "";
    if (!entries.length) {
      status.textContent = statusText || "No matches yet.";
      return;
    }
    status.textContent = `${entries.length} result${entries.length === 1 ? "" : "s"} • ${statusText}`;
    for (const entry of entries) {
      const li = document.createElement("li");
      const title = document.createElement("a");
      title.className = "hs-result-title";
      title.href = entry.href;
      title.textContent = entry.title || "Untitled";

      const meta = document.createElement("div");
      meta.className = "hs-result-meta";
      const badges = document.createElement("span");
      badges.className = "hs-result-badges";
      badges.textContent = entry.sources.join(" + ");
      const score = document.createElement("span");
      score.className = "hs-result-score";
      score.textContent = entry.score.toFixed(2);
      meta.append(badges, score);

      const excerpt = document.createElement("p");
      excerpt.className = "hs-result-excerpt";
      if (entry.sources[0] === "text") {
        // Pagefind pre-escapes excerpt HTML and injects only its own <mark>
        // highlight tags — rendering as HTML is the supported usage.
        excerpt.innerHTML = entry.excerpt || "No excerpt available.";
      } else {
        // Semantic excerpts embed the raw query string — plain text only.
        excerpt.textContent = entry.excerpt || "No excerpt available.";
      }

      li.append(title, meta, excerpt);
      list.appendChild(li);
    }
  }

  async function runQuery(root: HTMLElement, query: string) {
    const trimmed = query.trim();
    const requestId = ++activeRequest;
    const list = root.querySelector(".hs-results") as HTMLOListElement | null;
    const status = root.querySelector(".hs-status") as HTMLParagraphElement | null;
    if (!list || !status) return;

    if (!trimmed) {
      list.innerHTML = "";
      status.textContent = "Start with a title, phrase, or question.";
      return;
    }

    status.textContent = "Searching…";
    const [textResult, semanticResult] = await Promise.all([
      runTextSearch(trimmed),
      runSemanticSearch(trimmed),
    ]);

    if (requestId !== activeRequest) return;

    const merged = mergeResults(textResult.entries, semanticResult.entries, trimmed);
    const notes = [textResult.status, semanticResult.status].filter(Boolean);
    renderResults(root, merged, notes.join(" • "));
  }

  function wire() {
    const root = document.querySelector("[data-header-search]") as HTMLElement | null;
    if (!root || root.dataset.wired) return;
    root.dataset.wired = "1";
    const trigger = root.querySelector(".hs-trigger") as HTMLButtonElement | null;
    const panel = root.querySelector(".hs-panel") as HTMLElement | null;
    const form = root.querySelector(".hs-form") as HTMLFormElement | null;
    const input = root.querySelector("#hs-q") as HTMLInputElement | null;
    if (!trigger || !panel || !form || !input) return;

    const open = () => {
      panel.hidden = false;
      trigger.setAttribute("aria-expanded", "true");
      void (window as any).__loadPagefind?.(); // warm the text index while the reader types
      input.focus();
    };
    const close = () => {
      panel.hidden = true;
      trigger.setAttribute("aria-expanded", "false");
    };

    trigger.addEventListener("click", () => (panel.hidden ? open() : close()));
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      runQuery(root, input.value);
    });
    input.addEventListener("input", () => {
      clearTimeout(searchTimer);
      searchTimer = window.setTimeout(() => runQuery(root, input.value), 250);
    });
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !panel.hidden) close();
    });
    document.addEventListener("click", (event) => {
      if (!panel.hidden && event.target instanceof Node && !root.contains(event.target)) close();
    });
  }

  wire();
  document.addEventListener("astro:page-load", wire);
</script>

<style>
  .hs-root {
    position: relative;
    display: inline-flex;
  }
  .hs-trigger {
    border: 0;
    background: none;
    cursor: pointer;
    font: inherit;
    color: var(--muted);
    font-size: var(--text-sm);
    display: inline-flex;
    align-items: center;
    min-height: var(--tap-target);
    padding-inline: var(--space-unit);
  }
  .hs-trigger:hover,
  .hs-trigger[aria-expanded="true"] {
    color: var(--ink);
  }
  .hs-panel {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    z-index: 20;
    width: min(34rem, calc(100vw - 2rem));
    /* On narrow screens the trigger sits mid-header, so anchoring the panel
       to it pushes the panel past the left viewport edge. Making .hs-root
       static promotes the sticky .site-header to containing block: the panel
       then spans the viewport just below the header, however tall the
       wrapped nav is. (Override lives below, after the base rules.) */
    background: var(--bg-raised);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    box-shadow: 0 12px 40px rgb(0 0 0 / 0.35);
    padding: calc(var(--space-unit) * 1.25);
  }
  .hs-form input {
    width: 100%;
    font: inherit;
    color: var(--ink);
    background: var(--bg);
    border: 1px solid var(--hairline);
    border-radius: 8px;
    padding: 0.65em 0.9em;
    min-height: var(--tap-target);
  }
  .hs-form input:focus {
    outline: 2px solid var(--accent);
    border-color: var(--accent);
  }
  .hs-status {
    color: var(--muted);
    font-size: var(--text-sm);
    min-height: 1.3em;
    margin-block: 0.6em 0.4em;
  }
  .hs-results {
    margin: 0;
    padding-inline-start: 1.2em;
    display: grid;
    gap: 0.55em;
    max-height: min(55vh, 26rem);
    overflow-y: auto;
  }
  .hs-result-title {
    font-weight: 600;
    text-decoration: none;
  }
  .hs-result-meta {
    display: flex;
    gap: 0.6em;
    align-items: center;
    flex-wrap: wrap;
    margin-block: 0.15em;
    color: var(--muted);
    font-size: var(--text-sm);
  }
  .hs-result-badges {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .hs-result-score {
    font-family: var(--font-mono);
  }
  .hs-result-excerpt {
    color: var(--muted);
    font-size: var(--text-sm);
    margin: 0;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  @media (max-width: 640px) {
    .hs-root {
      position: static;
    }
    .hs-panel {
      top: calc(100% + 8px);
      left: 1rem;
      right: 1rem;
      width: auto;
    }
  }
</style>
