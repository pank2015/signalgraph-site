---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import PillarTag from "../../components/PillarTag.astro";
import FlowDiagram from "../../components/FlowDiagram.astro";
import Provenance from "../../components/Provenance.astro";
import Giscus from "../../components/Giscus.astro";
import { citationOrder, stripCites } from "../../lib/remark-claims.mjs";

export async function getStaticPaths() {
  const hideDrafts = !!(process.env.CI || process.env.CF_PAGES);
  const posts = await getCollection("posts", ({ data }) => !(hideDrafts && data.draft));
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const diagrams: Record<string, any> = import.meta.glob("../../../content/diagrams/*.json", {
  eager: true,
  import: "default",
});
const provenances: Record<string, any> = import.meta.glob("../../../content/provenance/*.json", {
  eager: true,
  import: "default",
});
const byName = (map: Record<string, any>, name?: string) =>
  name ? Object.entries(map).find(([k]) => k.endsWith(`/${name}`))?.[1] : undefined;

const diagram = byName(diagrams, post.data.diagram);
const provenance = byName(provenances, post.data.provenance);
const rawTldr = Array.isArray(post.data.tldr) ? post.data.tldr.filter(Boolean) : [];
// TL;DR bullets carry [c:id] markers (frontmatter, gated exactly like a body
// paragraph — see engine WS1) but bypass the markdown/remark pipeline that
// strips markers from the body, so a claim cited ONLY in the TL;DR must be
// folded into citationOrder here or it silently vanishes from the provenance
// disclosure while still being counted in the "verified" line above it.
const order = citationOrder(`${post.body ?? ""}\n${rawTldr.join("\n")}`);
const tldrEntries = rawTldr.map(stripCites); // display text only — never rendered with markers
const date = post.data.date.toISOString().slice(0, 10);
const claimCount = post.data.claims_cited ?? order.size;
const sourcesCount = post.data.sources_count ?? (provenance ? Object.keys(provenance.claims ?? {}).length : 0);
const FORMATS: Record<string, string> = {
  daily_signal: "Daily Signal",
  deep_dive: "Deep Dive",
  shift_report: "Shift Report",
  teardown: "Teardown",
  primer: "Primer",
};
---

<Base title={`${post.data.title} — Signalgraph`} description={post.data.description}>
  <article data-pagefind-body>
    <header class="post-head">
      <div class="meta">
        <time datetime={date}>{date}</time>
        <span class="fmt">{FORMATS[post.data.format]}</span>
        <PillarTag pillar={post.data.pillar} />
      </div>
      <h1>{post.data.title}</h1>
      <p class="dek">{post.data.description}</p>
      {tldrEntries.length > 0 && (
        <section class="tldr-card" aria-label="TL;DR">
          <h2>TL;DR</h2>
          <ul>
            {tldrEntries.map((item) => <li>{item}</li>)}
          </ul>
        </section>
      )}
      <a
        class="verified-line"
        href="#provenance"
        onclick="const node=document.getElementById('provenance'); if (node) { node.open=true; node.scrollIntoView({behavior:'smooth', block:'start'}); } return false;"
      >
        <span>✓ verified</span> — {claimCount} claim{claimCount === 1 ? "" : "s"}, {sourcesCount} source{sourcesCount === 1 ? "" : "s"}
      </a>
    </header>

    {diagram && <FlowDiagram dsl={diagram} />}

    <div class="prose">
      <Content />
    </div>

    {provenance && <Provenance provenance={provenance} order={order} claimCount={claimCount} sourcesCount={sourcesCount} />}

    <Giscus />

    <footer class="post-foot" data-pagefind-ignore>
      <p>
        Written by the Signalgraph engine from {claimCount} sourced claims; gated G1–G7; published by curator merge.
      </p>
    </footer>
  </article>
</Base>

<style>
  .post-head {
    max-width: var(--measure);
    margin-inline: auto;
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-unit);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
  }
  .fmt {
    color: var(--accent);
  }
  h1 {
    font-size: var(--text-display);
    margin: 0.4em 0 0.3em;
  }
  .dek {
    color: var(--muted);
    font-size: var(--text-lg);
    margin: 0 0 1em;
  }
  .tldr-card {
    border: 1px solid var(--hairline);
    border-radius: 12px;
    padding: calc(var(--space-unit) * 1.5);
    margin: 0 0 1rem;
    background: var(--bg-raised);
  }
  .tldr-card h2 {
    font-size: var(--text-sm);
    margin: 0 0 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }
  .tldr-card ul {
    margin: 0;
    padding-left: 1.2rem;
  }
  .verified-line {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--muted);
    font-size: var(--text-sm);
    margin-bottom: 1.5rem;
  }
  .verified-line:hover {
    color: var(--accent);
    text-decoration: none;
  }
  .post-foot {
    max-width: var(--measure);
    margin: calc(var(--space-unit) * 5) auto 0;
    padding-top: calc(var(--space-unit) * 2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--muted);
  }
</style>
